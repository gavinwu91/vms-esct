# 生产环境：只在打包时使用
NODE_ENV=production

VITE_DEV=false

# 请求路径
VITE_BASE_URL='https://192.168.88.192:48080'

# 文件上传类型：server - 后端上传， client - 前端直连上传，仅支持S3服务
VITE_UPLOAD_TYPE=server

# 接口地址
VITE_API_URL=/admin-api

# 是否删除debugger
VITE_DROP_DEBUGGER=true

# 是否删除console.log
VITE_DROP_CONSOLE=true

# 是否sourcemap
VITE_SOURCEMAP=false

# 打包路径
VITE_BASE_PATH=/vms

# 输出路径
VITE_OUT_DIR=dist-dev

VITE_GOVIEW_URL='http://192.168.200.165:9696'

VITE_CAPTURE_URL='https://192.168.200.165:9996'

VITE_MALL_H5_DOMAIN='http://192.168.88.192:48080'

# 默认账户密码 test1 test1 密码123456
VITE_APP_DEFAULT_LOGIN_TENANT = roadmin
VITE_APP_DEFAULT_LOGIN_USERNAME = roadmin
VITE_APP_DEFAULT_LOGIN_PASSWORD = admin123
VITE_APP_LOGO=RO

# VITE_APP_DEFAULT_LOGIN_TENANT = otpadmin
# VITE_APP_DEFAULT_LOGIN_USERNAME = otpadmin
# VITE_APP_DEFAULT_LOGIN_PASSWORD = admin123
